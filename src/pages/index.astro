	/* Special Dark Theme Enhancements */
	:global(.profile-section:hover .profile-name) {
		animation: textPulse 2s ease-in-out infinite;
	}

	@keyframes textPulse {
		0%, 100% { 
			transform: scale(1);
			filter: drop-shadow(0 0 10px rgba(255, 140, 0, 0.3));
		}
		50% { 
			transform: scale(1.02);
			filter: drop-shadow(0 0 25px rgba(255, 140, 0, 0.6));
		}
	}

	/* Loading Screen Styles */
	:global(.loading-screen) {
		position: fixed;
		top: 0;
		left: 0;
		width: 100vw;
		height: 100vh;
		background: 
			radial-gradient(circle at 30% 20%, rgba(139, 69, 19, 0.4) 0%, transparent 50%),
			radial-gradient(circle at 70% 80%, rgba(255, 140, 0, 0.3) 0%, transparent 50%),
			radial-gradient(circle at 20% 80%, rgba(220, 20, 60, 0.3) 0%, transparent 50%),
			linear-gradient(135deg, #0a0a0a 0%, #1a1a1a 25%, #2d2d2d 50%, #1a1a1a 75%, #0a0a0a 100%);
		display: flex;
		align-items: center;
		justify-content: center;
		z-index: 9999;
		transition: all 0.8s ease;
	}

	:global(.loading-screen.fade-out) {
		opacity: 0;
		visibility: hidden;
		transform: scale(1.1);
	}

	:global(.loading-content) {
		text-align: center;
		position: relative;
	}

	/* Loading Logo Animation */
	:global(.loading-logo) {
		position: relative;
		width: 180px;
		height: 180px;
		margin: 0 auto 2rem;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	:global(.logo-ring) {
		position: absolute;
		border: 2px solid transparent;
		border-radius: 50%;
		opacity: 0;
		transform: scale(0);
		transition: all 0.6s ease;
	}

	:global(.logo-ring:nth-child(1)) {
		width: 80px;
		height: 80px;
		border-top: 2px solid #ff8c00;
		border-right: 2px solid #ff8c00;
		animation: spin 2s linear infinite;
	}

	:global(.logo-ring.ring-2) {
		width: 120px;
		height: 120px;
		border-left: 2px solid #dc143c;
		border-bottom: 2px solid #dc143c;
		animation: spin 2.5s linear infinite reverse;
	}

	:global(.logo-ring.ring-3) {
		width: 160px;
		height: 160px;
		border-top: 2px solid #8b4513;
		border-right: 2px solid #8b4513;
		animation: spin 3s linear infinite;
	}

	:global(.loading-logo.animate .logo-ring) {
		opacity: 1;
		transform: scale(1);
	}

	/* 双语Logo容器 */
	:global(.logo-text-container) {
		text-align: center;
		position: relative;
		z-index: 2;
		opacity: 0;
		transform: scale(0) rotate(180deg);
		transition: all 1s cubic-bezier(0.68, -0.55, 0.265, 1.55) 0.5s;
	}

	:global(.loading-logo.animate .logo-text-container) {
		opacity: 1;
		transform: scale(1) rotate(0deg);
	}

	/* 主Logo文字 */
	:global(.logo-text-main) {
		display: flex;
		align-items: center;
		justify-content: center;
		margin-bottom: 0.5rem;
		font-family: 'Kalam', cursive;
		font-weight: 700;
		position: relative;
	}

	/* 英文部分 */
	:global(.logo-english) {
		font-size: 2.2rem;
		color: #ff8c00;
		text-shadow: 
			0 0 10px rgba(255, 140, 0, 0.6),
			0 0 20px rgba(255, 140, 0, 0.4);
		transform: translateX(-20px);
		opacity: 0;
		animation: slideInLeft 0.8s ease-out 1s forwards;
	}

	/* 点号 */
	:global(.logo-dot) {
		font-size: 2.2rem;
		color: #ffffff;
		margin: 0 0.3rem;
		text-shadow: 0 0 15px rgba(255, 255, 255, 0.8);
		transform: scale(0);
		opacity: 0;
		animation: popIn 0.6s ease-out 1.5s forwards;
	}

	/* 中文部分 */
	:global(.logo-chinese) {
		font-size: 2.2rem;
		color: #dc143c;
		text-shadow: 
			0 0 10px rgba(220, 20, 60, 0.6),
			0 0 20px rgba(220, 20, 60, 0.4);
		transform: translateX(20px);
		opacity: 0;
		animation: slideInRight 0.8s ease-out 1.8s forwards;
	}

	/* 副标题 */
	:global(.logo-subtitle) {
		font-size: 0.9rem;
		color: rgba(255, 255, 255, 0.8);
		text-transform: uppercase;
		letter-spacing: 3px;
		font-weight: 400;
		text-shadow: 0 0 10px rgba(255, 255, 255, 0.3);
		transform: translateY(20px);
		opacity: 0;
		animation: fadeInUp 0.6s ease-out 2.2s forwards;
	}

	/* Logo动画关键帧 */
	@keyframes slideInLeft {
		0% {
			transform: translateX(-20px);
			opacity: 0;
		}
		100% {
			transform: translateX(0);
			opacity: 1;
		}
	}

	@keyframes slideInRight {
		0% {
			transform: translateX(20px);
			opacity: 0;
		}
		100% {
			transform: translateX(0);
			opacity: 1;
		}
	}

	@keyframes popIn {
		0% {
			transform: scale(0);
			opacity: 0;
		}
		50% {
			transform: scale(1.3);
			opacity: 1;
		}
		100% {
			transform: scale(1);
			opacity: 1;
		}
	}

	@keyframes fadeInUp {
		0% {
			transform: translateY(20px);
			opacity: 0;
		}
		100% {
			transform: translateY(0);
			opacity: 1;
		}
	}

	/* Logo hover效果增强 */
	:global(.logo-english:hover) {
		animation: logoGlow 0.3s ease-in-out;
	}

	:global(.logo-chinese:hover) {
		animation: logoGlow 0.3s ease-in-out;
	}

	@keyframes logoGlow {
		0%, 100% {
			text-shadow: 
				0 0 10px currentColor,
				0 0 20px currentColor;
		}
		50% {
			text-shadow: 
				0 0 20px currentColor,
				0 0 30px currentColor,
				0 0 40px currentColor;
		}
	}

	/* 旧的logo-text样式移除，替换为新的 */

	/* Glitch Text Effect */
	:global(.loading-text) {
		margin-bottom: 2rem;
		opacity: 0;
		transform: translateY(20px);
		transition: all 0.6s ease 0.5s;
	}

	:global(.loading-text.show) {
		opacity: 1;
		transform: translateY(0);
	}

	:global(.glitch-text) {
		font-family: 'Kalam', cursive;
		font-size: 1.2rem;
		font-weight: 600;
		color: #ffffff;
		position: relative;
		text-transform: uppercase;
		letter-spacing: 2px;
	}

	:global(.glitch-text::before),
	:global(.glitch-text::after) {
		content: attr(data-text);
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
	}

	:global(.glitch-text::before) {
		animation: glitch-1 2s infinite;
		color: #ff8c00;
		z-index: -1;
	}

	:global(.glitch-text::after) {
		animation: glitch-2 2s infinite;
		color: #dc143c;
		z-index: -2;
	}

	@keyframes glitch-1 {
		0%, 100% { transform: translate(0); }
		20% { transform: translate(-2px, 2px); }
		40% { transform: translate(-2px, -2px); }
		60% { transform: translate(2px, 2px); }
		80% { transform: translate(2px, -2px); }
	}

	@keyframes glitch-2 {
		0%, 100% { transform: translate(0); }
		20% { transform: translate(2px, 2px); }
		40% { transform: translate(2px, -2px); }
		60% { transform: translate(-2px, 2px); }
		80% { transform: translate(-2px, -2px); }
	}

	/* Progress Bar */
	:global(.progress-bar) {
		width: 300px;
		height: 4px;
		background: rgba(255, 255, 255, 0.1);
		border-radius: 2px;
		margin: 0 auto;
		overflow: hidden;
		opacity: 0;
		transform: scaleX(0);
		transition: all 0.6s ease 0.8s;
	}

	:global(.progress-bar.animate) {
		opacity: 1;
		transform: scaleX(1);
	}

	:global(.progress-fill) {
		height: 100%;
		background: linear-gradient(90deg, #ff8c00, #dc143c, #8b4513);
		border-radius: 2px;
		transform: translateX(-100%);
		animation: progress 2s ease-out forwards;
	}

	@keyframes progress {
		0% { transform: translateX(-100%); }
		100% { transform: translateX(0); }
	}

	/* Particle Explosion */
	:global(.particle-explosion) {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		width: 1px;
		height: 1px;
	}

	:global(.particle) {
		position: absolute;
		width: 4px;
		height: 4px;
		background: radial-gradient(circle, 
			rgba(255, 140, 0, 1) 0%, 
			rgba(220, 20, 60, 0.8) 50%, 
			transparent 100%);
		border-radius: 50%;
		animation: particle-explode 1s ease-out forwards;
		animation-delay: var(--delay);
		opacity: 0;
	}

	@keyframes particle-explode {
		0% {
			opacity: 1;
			transform: rotate(var(--angle)) translateX(0) scale(0);
		}
		50% {
			opacity: 1;
			transform: rotate(var(--angle)) translateX(calc(var(--distance) * 0.7)) scale(1);
		}
		100% {
			opacity: 0;
			transform: rotate(var(--angle)) translateX(var(--distance)) scale(0);
		}
	}

	/* Main Content Animation */
	:global(.main-content) {
		opacity: 0;
		transform: scale(0.9);
		transition: all 1s ease;
	}

	:global(.main-content.show) {
		opacity: 1;
		transform: scale(1);
	}

	/* Entrance Animations */
	:global(.entrance-animation) {
		opacity: 0;
		transform: translateY(60px) scale(0.8);
		transition: all 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
	}

	:global(.entrance-animation.phase-1) {
		animation: entrance-fade-up 0.8s ease-out 0.2s forwards;
	}

	:global(.entrance-animation.phase-2) {
		animation: entrance-fade-up 0.8s ease-out 0.4s forwards;
	}

	:global(.entrance-animation.phase-3) {
		animation: entrance-fade-up 0.8s ease-out 0.6s forwards;
	}

	:global(.entrance-animation.phase-4) {
		animation: entrance-fade-up 0.8s ease-out 0.8s forwards;
	}

	:global(.entrance-animation.phase-5) {
		animation: entrance-fade-up 0.8s ease-out 1.0s forwards;
	}

	:global(.entrance-animation.phase-6) {
		animation: entrance-fade-up 0.8s ease-out 1.2s forwards;
	}

	:global(.entrance-animation.phase-7) {
		animation: entrance-fade-up 0.8s ease-out 1.4s forwards;
	}

	:global(.entrance-animation.phase-8) {
		animation: entrance-fade-up 0.8s ease-out 1.6s forwards;
	}

	:global(.entrance-animation.phase-9) {
		animation: entrance-fade-up 0.8s ease-out 1.8s forwards;
	}

	:global(.entrance-animation.phase-10) {
		animation: entrance-fade-up 0.8s ease-out 2.0s forwards;
	}

	:global(.entrance-animation.phase-11) {
		animation: entrance-fade-up 0.8s ease-out 2.2s forwards;
	}

	@keyframes entrance-fade-up {
		0% {
			opacity: 0;
			transform: translateY(60px) scale(0.8);
		}
		100% {
			opacity: 1;
			transform: translateY(0) scale(1);
		}
	}

	/* Mouse Glow Effect */
	:global(.mouse-glow) {
		position: fixed;
		width: 200px;
		height: 200px;
		background: radial-gradient(circle, rgba(255, 140, 0, 0.15) 0%, rgba(220, 20, 60, 0.1) 50%, transparent 70%);
		border-radius: 50%;
		pointer-events: none;
		z-index: 1;
		transition: all 0.1s ease;
		mix-blend-mode: screen;
	}

