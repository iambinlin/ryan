---
import Layout from '../layouts/Layout.astro';
import HomePage from '../components/home/index'
---

<Layout title="It's ryanwang">
	<main class="animated-gradient-bg">
		<HomePage client:only="react" />
	</main>
</Layout>
<script is:inline  src="https://source.binlin.wang/heti.min.js" defer></script>
<script  is:inline defer>
	try {
		const heti = new Heti('.heti');
		heti.autoSpacing(); // 自动进行中西文混排美化和标点挤压
	} catch (e) {
		//
	}
</script>
<!-- Google tag (gtag.js) -->
<script is:inline async src="https://source.binlin.wang/googleGA.min.js?id=G-XYK26MQFXT"></script>
<script is:inline>
	window.dataLayer = window.dataLayer || [];
	function gtag(){dataLayer.push(arguments);}
	window.gtag = gtag;
	gtag('js', new Date());

	gtag('config', 'G-XYK26MQFXT');
</script>


<style>
	@import url('https://fonts.googleapis.com/css2?family=Kalam:wght@300;400;700&family=Creepster&family=Nosifer&family=Butcherman&display=swap');
	@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');

	/* Modern CSS Reset */
	*,
	*::before,
	*::after {
		box-sizing: border-box;
	}

	body {
		margin: 0;
		font-family: 'Kalam', 'Inter', cursive, sans-serif;
		background: #0a0a0a;
		min-height: 100vh;
		color: #ffffff;
		line-height: 1.6;
		overflow-x: hidden;
	}

	.animated-gradient-bg {
		background: 
			radial-gradient(circle at 30% 20%, rgba(99, 102, 241, 0.15) 0%, transparent 50%),
			radial-gradient(circle at 70% 80%, rgba(168, 85, 247, 0.12) 0%, transparent 50%),
			radial-gradient(circle at 20% 80%, rgba(59, 130, 246, 0.1) 0%, transparent 50%),
			linear-gradient(135deg, #0f0f23 0%, #1a1a2e 25%, #16213e 50%, #1a1a2e 75%, #0f0f23 100%);
		min-height: 100vh;
		position: relative;
		overflow: hidden;
		animation: modernPulse 12s ease-in-out infinite alternate;
	}

	@keyframes modernPulse {
		0% { 
			background: 
				radial-gradient(circle at 30% 20%, rgba(99, 102, 241, 0.1) 0%, transparent 50%),
				radial-gradient(circle at 70% 80%, rgba(168, 85, 247, 0.08) 0%, transparent 50%),
				radial-gradient(circle at 20% 80%, rgba(59, 130, 246, 0.06) 0%, transparent 50%),
				linear-gradient(135deg, #0f0f23 0%, #1a1a2e 25%, #16213e 50%, #1a1a2e 75%, #0f0f23 100%);
		}
		100% { 
			background: 
				radial-gradient(circle at 30% 20%, rgba(99, 102, 241, 0.2) 0%, transparent 50%),
				radial-gradient(circle at 70% 80%, rgba(168, 85, 247, 0.15) 0%, transparent 50%),
				radial-gradient(circle at 20% 80%, rgba(59, 130, 246, 0.12) 0%, transparent 50%),
				linear-gradient(135deg, #0f0f23 0%, #1a1a2e 25%, #16213e 50%, #1a1a2e 75%, #0f0f23 100%);
		}
	}

	/* Floating particles effect */
	.animated-gradient-bg::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background-image: 
			radial-gradient(2px 2px at 20px 30px, rgba(99, 102, 241, 0.4), transparent),
			radial-gradient(2px 2px at 40px 70px, rgba(168, 85, 247, 0.3), transparent),
			radial-gradient(1px 1px at 90px 40px, rgba(59, 130, 246, 0.5), transparent),
			radial-gradient(1px 1px at 130px 80px, rgba(99, 102, 241, 0.3), transparent),
			radial-gradient(2px 2px at 160px 30px, rgba(168, 85, 247, 0.2), transparent);
		background-repeat: repeat;
		background-size: 200px 100px;
		animation: float 25s linear infinite;
		pointer-events: none;
	}

	@keyframes float {
		0% { transform: translateY(100vh) rotate(0deg); }
		100% { transform: translateY(-100vh) rotate(360deg); }
	}

	/* Scanning line effect */
	.animated-gradient-bg::after {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 2px;
		background: linear-gradient(90deg, transparent, rgba(99, 102, 241, 0.6), transparent);
		animation: scan 6s linear infinite;
		pointer-events: none;
	}

	@keyframes scan {
		0% { transform: translateY(0); }
		100% { transform: translateY(100vh); }
	}

	/* Language Toggle */
	:global(.lang-toggle) {
		display: inline-flex;
		align-items: center;
		padding: 12px 24px;
		background: rgba(0, 0, 0, 0.3);
		backdrop-filter: blur(20px);
		border-radius: 50px;
		border: 1px solid rgba(255, 255, 255, 0.1);
		cursor: pointer;
		transition: all 0.3s ease;
		font-size: 14px;
		font-weight: 500;
		box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
	}

	:global(.lang-toggle:hover) {
		transform: translateY(-2px);
		background: rgba(0, 0, 0, 0.4);
		border-color: rgba(99, 102, 241, 0.3);
		box-shadow: 0 12px 40px rgba(99, 102, 241, 0.1);
	}

	:global(.lang-option) {
		padding: 6px 12px;
		border-radius: 20px;
		transition: all 0.3s ease;
		cursor: pointer;
		position: relative;
	}

	:global(.lang-option.active) {
		background: linear-gradient(135deg, #6366f1, #8b5cf6);
		color: #ffffff;
		font-weight: 600;
		box-shadow: 0 4px 15px rgba(99, 102, 241, 0.3);
	}

	/* Profile Section */
	:global(.profile-section) {
		text-align: center;
		margin-bottom: 4rem;
		position: relative;
		z-index: 10;
	}

	:global(.profile-image-container) {
		margin-bottom: 2rem;
		display: inline-block;
		position: relative;
	}

	:global(.profile-image-container::before) {
		content: '';
		position: absolute;
		top: -10px;
		left: -10px;
		right: -10px;
		bottom: -10px;
		border-radius: 50%;
		background: conic-gradient(from 0deg, #ff8c00, #dc143c, #8b4513, #ff8c00);
		animation: rotate 4s linear infinite;
		z-index: -1;
	}

	@keyframes rotate {
		0% { transform: rotate(0deg); }
		100% { transform: rotate(360deg); }
	}

	:global(.profile-avatar-wrapper) {
		position: relative;
		display: inline-block;
	}

	:global(.profile-avatar.loading) {
		opacity: 0.6;
		filter: blur(3px);
		transform: scale(0.9);
	}

	:global(.profile-avatar.loaded) {
		opacity: 1;
		filter: blur(0);
		transform: scale(1);
		transition: all 0.8s ease;
	}

	:global(.profile-avatar-wrapper::after) {
		content: '';
		position: absolute;
		top: 50%;
		left: 50%;
		width: 30px;
		height: 30px;
		border: 2px solid rgba(255, 140, 0, 0.3);
		border-top: 2px solid #ff8c00;
		border-radius: 50%;
		transform: translate(-50%, -50%);
		animation: spin 1s linear infinite;
		opacity: 0;
		transition: opacity 0.3s ease;
		z-index: 4;
	}

	:global(.profile-avatar-wrapper:has(.profile-avatar.loading)::after) {
		opacity: 1;
	}

	:global(.profile-avatar) {
		width: 140px;
		height: 140px;
		border-radius: 50%;
		border: 4px solid rgba(0, 0, 0, 0.8);
		transition: all 0.4s ease;
		box-shadow: 
			0 0 30px rgba(255, 140, 0, 0.3),
			inset 0 0 20px rgba(0, 0, 0, 0.3);
		position: relative;
		z-index: 2;
	}

	:global(.profile-avatar:hover) {
		transform: scale(1.1);
		box-shadow: 
			0 0 50px rgba(255, 140, 0, 0.6),
			inset 0 0 30px rgba(0, 0, 0, 0.2);
	}

	:global(.profile-name) {
		font-family: 'Kalam', cursive;
		font-size: 3.5rem;
		font-weight: 700;
		margin: 0 0 1rem 0;
		background: linear-gradient(135deg, #ff8c00 0%, #dc143c 50%, #8b4513 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		text-shadow: 0 0 30px rgba(255, 140, 0, 0.3);
		animation: textGlow 3s ease-in-out infinite alternate;
		position: relative;
	}

	@keyframes textGlow {
		0% { 
			filter: drop-shadow(0 0 10px rgba(255, 140, 0, 0.3));
		}
		100% { 
			filter: drop-shadow(0 0 20px rgba(255, 140, 0, 0.6));
		}
	}

	:global(.profile-title) {
		font-family: 'Kalam', cursive;
		font-size: 1.4rem;
		font-weight: 400;
		color: rgba(255, 255, 255, 0.8);
		margin: 0;
		letter-spacing: 1px;
	}

	/* Layered Visual System - 无边界分层视觉系统 */
	:global(.layered-content) {
		position: relative;
		padding: 1rem 0;
		background: transparent;
	}

	/* 分层背景效果 */
	:global(.layered-content::before) {
		content: '';
		position: absolute;
		top: -20%;
		left: -10%;
		right: -10%;
		bottom: -20%;
		background: 
			radial-gradient(ellipse 800px 600px at 20% 40%, rgba(99, 102, 241, 0.03) 0%, transparent 50%),
			radial-gradient(ellipse 600px 800px at 80% 20%, rgba(168, 85, 247, 0.02) 0%, transparent 50%),
			radial-gradient(ellipse 400px 400px at 50% 80%, rgba(59, 130, 246, 0.025) 0%, transparent 50%);
		pointer-events: none;
		animation: layerFloat 20s ease-in-out infinite;
	}

	@keyframes layerFloat {
		0%, 100% { 
			transform: translate(0, 0) rotate(0deg); 
			opacity: 0.8;
		}
		33% { 
			transform: translate(-2%, 2%) rotate(1deg); 
			opacity: 1;
		}
		66% { 
			transform: translate(2%, -1%) rotate(-0.5deg); 
			opacity: 0.9;
		}
	}

	/* 内容层级系统 */
	:global(.content-layer) {
		position: relative;
		margin: 2.5rem 0;
		padding: 0;
		background: transparent;
		border: none;
		transform-style: preserve-3d;
		transition: all 0.6s cubic-bezier(0.23, 1, 0.320, 1);
	}

	/* Layer 1 - 最前景层 */
	:global(.layer-1) {
		z-index: 30;
		transform: translateZ(30px) perspective(1000px);
	}

	:global(.layer-1:hover) {
		transform: translateZ(50px) translateY(-8px) perspective(1000px);
	}

	/* Layer 2 - 中景层 */
	:global(.layer-2) {
		z-index: 20;
		transform: translateZ(20px) perspective(1000px);
		margin-left: 2rem;
	}

	:global(.layer-2:hover) {
		transform: translateZ(40px) translateY(-6px) perspective(1000px);
		margin-left: 2rem;
	}

	/* Layer 3 - 背景层 */
	:global(.layer-3) {
		z-index: 10;
		transform: translateZ(10px) perspective(1000px);
		margin-right: 2rem;
	}

	:global(.layer-3:hover) {
		transform: translateZ(30px) translateY(-4px) perspective(1000px);
		margin-right: 2rem;
	}

	/* 动态光影层 */
	:global(.content-layer::before) {
		content: '';
		position: absolute;
		top: -2rem;
		left: -2rem;
		right: -2rem;
		bottom: -2rem;
		background: radial-gradient(ellipse at center, rgba(99, 102, 241, 0.01) 0%, transparent 70%);
		opacity: 0;
		transition: all 0.8s ease;
		pointer-events: none;
		border-radius: 50%;
		transform: scale(0.8);
	}

	:global(.content-layer:hover::before) {
		opacity: 1;
		transform: scale(1.2);
		background: radial-gradient(ellipse at center, rgba(99, 102, 241, 0.03) 0%, rgba(168, 85, 247, 0.01) 40%, transparent 70%);
	}

	/* Floating Section Titles - 漂浮式标题 */
	:global(.section-title) {
		font-family: 'Kalam', cursive;
		font-size: 2rem;
		font-weight: 700;
		margin: 0 0 2rem 0;
		color: transparent;
		background: linear-gradient(135deg, 
			#f8fafc 0%, 
			#e2e8f0 20%, 
			#6366f1 40%, 
			#8b5cf6 60%, 
			#ec4899 80%, 
			#f97316 100%);
		background-size: 300% 300%;
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		position: relative;
		animation: gradientFlow 8s ease-in-out infinite;
		filter: drop-shadow(0 0 30px rgba(99, 102, 241, 0.2));
		transform: translateZ(20px);
	}

	@keyframes gradientFlow {
		0%, 100% { background-position: 0% 50%; }
		25% { background-position: 25% 25%; }
		50% { background-position: 100% 50%; }
		75% { background-position: 75% 75%; }
	}

	/* 标题连接线 */
	:global(.section-title::after) {
		content: '';
		position: absolute;
		bottom: -12px;
		left: 0;
		width: 0;
		height: 2px;
		background: linear-gradient(90deg, 
			#6366f1, 
			#8b5cf6, 
			#ec4899, 
			#f97316);
		border-radius: 1px;
		transition: width 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
		box-shadow: 0 0 15px rgba(99, 102, 241, 0.4);
	}

	:global(.content-layer:hover .section-title::after) {
		width: 80px;
	}

	/* 文本内容分层 */
	:global(.prose-content) {
		position: relative;
		z-index: 2;
	}

	:global(.prose-block) {
		font-family: 'Kalam', cursive;
		font-size: 1.1rem;
		line-height: 1.8;
		color: rgba(255, 255, 255, 0.85);
		font-weight: 400;
		margin: 0 0 1.5rem 0;
		padding: 0.5rem 0;
		position: relative;
		transition: all 0.4s ease;
		transform: translateZ(10px);
	}

	:global(.prose-block::before) {
		content: '';
		position: absolute;
		left: -1rem;
		top: 0;
		bottom: 0;
		width: 2px;
		background: linear-gradient(180deg, 
			transparent 0%, 
			rgba(99, 102, 241, 0.3) 20%, 
			rgba(168, 85, 247, 0.5) 50%, 
			rgba(99, 102, 241, 0.3) 80%, 
			transparent 100%);
		opacity: 0;
		transition: all 0.4s ease;
		border-radius: 1px;
	}

	:global(.content-layer:hover .prose-block::before) {
		opacity: 1;
		left: -1.5rem;
	}

	:global(.content-layer:hover .prose-block) {
		transform: translateZ(15px) translateX(0.5rem);
		color: rgba(255, 255, 255, 0.95);
	}

	:global(.section-subtitle) {
		font-family: 'Kalam', cursive;
		font-size: 1.2rem;
		color: rgba(255, 255, 255, 0.7);
		margin-bottom: 1.5rem;
		font-weight: 400;
		position: relative;
		transform: translateZ(5px);
	}

	/* Premium Links - 顶级链接设计 */
	:global(.text-link) {
		color: #8b5cf6;
		text-decoration: none;
		font-weight: 600;
		position: relative;
		transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
		padding: 4px 8px;
		border-radius: 6px;
		background: rgba(139, 92, 246, 0.08);
		backdrop-filter: blur(10px);
		border: 1px solid rgba(139, 92, 246, 0.1);
	}

	:global(.text-link::before) {
		content: '';
		position: absolute;
		bottom: -1px;
		left: 0;
		width: 0;
		height: 2px;
		background: linear-gradient(90deg, #6366f1, #8b5cf6, #ec4899);
		transition: width 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
		border-radius: 1px;
	}

	:global(.text-link:hover) {
		background: rgba(139, 92, 246, 0.15);
		border-color: rgba(139, 92, 246, 0.3);
		color: #a78bfa;
		transform: translateY(-1px);
		box-shadow: 0 4px 12px rgba(139, 92, 246, 0.15);
	}

	:global(.text-link:hover::before) {
		width: 100%;
	}

	/* Projects Layer - 精致项目展示 */
	:global(.projects-layer) {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1.25rem;
		margin-top: 1.5rem;
		position: relative;
		transform: translateZ(15px);
		max-width: 600px;
		margin-left: auto;
		margin-right: auto;
	}

	:global(.project-item) {
		display: flex;
		flex-direction: column;
		align-items: center;
		padding: 2rem 1.5rem;
		background: rgba(255, 255, 255, 0.03);
		backdrop-filter: blur(15px);
		border: 1px solid rgba(99, 102, 241, 0.12);
		border-radius: 20px;
		text-decoration: none;
		color: #ffffff;
		transition: all 0.5s cubic-bezier(0.23, 1, 0.320, 1);
		text-align: center;
		position: relative;
		overflow: hidden;
		min-height: 140px;
		justify-content: center;
		box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15);
	}

	/* 项目卡片渐变背景 */
	:global(.project-item::before) {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: linear-gradient(135deg, 
			rgba(99, 102, 241, 0.05) 0%, 
			rgba(168, 85, 247, 0.03) 50%,
			rgba(59, 130, 246, 0.05) 100%);
		opacity: 0;
		transition: all 0.5s ease;
		border-radius: 20px;
	}

	:global(.project-item:hover::before) {
		opacity: 1;
	}

	:global(.project-item:hover) {
		transform: translateY(-8px) translateZ(5px) scale(1.03);
		border-color: rgba(99, 102, 241, 0.25);
		box-shadow: 
			0 20px 60px rgba(99, 102, 241, 0.15),
			0 8px 20px rgba(0, 0, 0, 0.2);
	}

	/* 顶部光条 */
	:global(.project-item::after) {
		content: '';
		position: absolute;
		top: 0;
		left: 20%;
		right: 20%;
		height: 2px;
		background: linear-gradient(90deg, 
			transparent, 
			rgba(99, 102, 241, 0.6), 
			rgba(168, 85, 247, 0.8), 
			rgba(99, 102, 241, 0.6), 
			transparent);
		opacity: 0;
		transition: all 0.4s ease;
		pointer-events: none;
		border-radius: 0 0 50% 50%;
	}

	:global(.project-item:hover) {
		transform: translateY(-6px) scale(1.03);
		background: rgba(255, 255, 255, 0.04);
		border-color: rgba(99, 102, 241, 0.2);
		box-shadow: 
			0 12px 40px rgba(0, 0, 0, 0.15),
			0 4px 12px rgba(99, 102, 241, 0.1);
	}

	:global(.project-item:hover::before) {
		opacity: 1;
	}

	:global(.project-item:hover::after) {
		opacity: 1;
		animation: topShimmer 2s ease-in-out infinite;
	}

	@keyframes topShimmer {
		0%, 100% { 
			left: 20%; 
			right: 20%; 
			opacity: 0.4;
		}
		50% { 
			left: 10%; 
			right: 10%; 
			opacity: 0.8;
		}
	}

	:global(.project-icon) {
		width: 3rem;
		height: 3rem;
		margin-bottom: 1rem;
		transition: all 0.5s cubic-bezier(0.23, 1, 0.320, 1);
		filter: drop-shadow(0 0 12px rgba(99, 102, 241, 0.4));
		position: relative;
		z-index: 2;
	}

	:global(.project-item:hover .project-icon) {
		transform: scale(1.2) rotate(-3deg);
		filter: drop-shadow(0 0 20px rgba(99, 102, 241, 0.6));
	}

	:global(.project-name) {
		font-family: 'Kalam', cursive;
		font-size: 1rem;
		font-weight: 600;
		color: rgba(255, 255, 255, 0.9);
		position: relative;
		z-index: 2;
		transition: all 0.3s ease;
		margin: 0;
		letter-spacing: 0.5px;
	}

	:global(.project-item:hover .project-name) {
		color: #ffffff;
		text-shadow: 0 0 8px rgba(99, 102, 241, 0.4);
	}

	/* WeChat Layer - 微信浮动层 */
	:global(.wechat-layer) {
		display: grid;
		grid-template-columns: 1fr auto;
		gap: 3rem;
		align-items: center;
		position: relative;
		transform: translateZ(10px);
	}

	:global(.wechat-content) {
		position: relative;
		z-index: 2;
	}

	:global(.wechat-visual) {
		position: relative;
		display: flex;
		justify-content: center;
		align-items: center;
		transform: translateZ(20px);
	}

	/* 二维码光环效果 */
	:global(.wechat-visual::before) {
		content: '';
		position: absolute;
		top: 50%;
		left: 50%;
		width: 280px;
		height: 280px;
		border: 1px dashed rgba(99, 102, 241, 0.2);
		border-radius: 50%;
		transform: translate(-50%, -50%) rotate(0deg);
		animation: qrOrbit 15s linear infinite;
		opacity: 0.4;
		pointer-events: none;
	}

	@keyframes qrOrbit {
		0% { transform: translate(-50%, -50%) rotate(0deg); }
		100% { transform: translate(-50%, -50%) rotate(360deg); }
	}

	:global(.qr-image) {
		position: relative;
		z-index: 2;
		transition: all 0.4s ease;
		transform: translateZ(15px);
		border-radius: 16px;
		overflow: hidden;
		box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
	}

	:global(.wechat-visual:hover .qr-image) {
		transform: translateZ(25px) scale(1.05);
		box-shadow: 0 15px 40px rgba(0, 0, 0, 0.3);
	}

	:global(.wechat-qr::before) {
		content: '';
		position: absolute;
		top: -15px;
		left: -15px;
		right: -15px;
		bottom: -15px;
		border-radius: 25px;
		background: linear-gradient(45deg, #ff8c00, #dc143c, #8b4513, #ff8c00);
		background-size: 300% 300%;
		animation: gradientMove 4s ease infinite;
		z-index: -1;
	}

	@keyframes gradientMove {
		0% { background-position: 0% 50%; }
		50% { background-position: 100% 50%; }
		100% { background-position: 0% 50%; }
	}

	:global(.qr-code) {
		width: 100%;
		max-width: 280px;
		min-width: 200px;
		height: auto;
		border-radius: 20px;
		transition: all 0.4s ease;
		box-shadow: 0 15px 50px rgba(0, 0, 0, 0.4);
		position: relative;
		z-index: 2;
		object-fit: cover;
	}

	:global(.qr-code:hover) {
		transform: scale(1.05) rotate(2deg);
		box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
	}

	/* QR Code Loading Animation */
	:global(.qr-code-container) {
		position: relative;
		overflow: hidden;
		border-radius: 20px;
	}

	:global(.qr-code.loading) {
		opacity: 0.7;
		filter: blur(5px);
		transform: scale(0.95);
	}

	:global(.qr-code.loaded) {
		opacity: 1;
		filter: blur(0);
		transform: scale(1);
		transition: all 0.6s ease;
	}

	:global(.qr-code-container::before) {
		content: '';
		position: absolute;
		top: 0;
		left: -100%;
		width: 100%;
		height: 100%;
		background: linear-gradient(90deg, 
			transparent, 
			rgba(255, 140, 0, 0.3), 
			transparent);
		animation: shimmer 2s infinite;
		z-index: 3;
		opacity: 0;
		transition: opacity 0.3s ease;
	}

	:global(.qr-code.loading + .qr-code-container::before),
	:global(.qr-code-container:has(.qr-code.loading)::before) {
		opacity: 1;
	}

	@keyframes shimmer {
		0% { left: -100%; }
		100% { left: 100%; }
	}

	/* Loading skeleton for QR code */
	:global(.qr-code-container::after) {
		content: '';
		position: absolute;
		top: 50%;
		left: 50%;
		width: 40px;
		height: 40px;
		border: 3px solid rgba(255, 140, 0, 0.3);
		border-top: 3px solid #ff8c00;
		border-radius: 50%;
		transform: translate(-50%, -50%);
		animation: spin 1s linear infinite;
		opacity: 0;
		transition: opacity 0.3s ease;
		z-index: 4;
	}

	:global(.qr-code.loading + .qr-code-container::after),
	:global(.qr-code-container:has(.qr-code.loading)::after) {
		opacity: 1;
	}

	@keyframes spin {
		0% { transform: translate(-50%, -50%) rotate(0deg); }
		100% { transform: translate(-50%, -50%) rotate(360deg); }
	}

	/* Animations */
	@keyframes fadeInUp {
		from {
			opacity: 0;
			transform: translateY(50px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	:global(.fade-in) {
		animation: fadeInUp 1s ease-out;
	}

	:global(.fade-in-delay-1) {
		animation: fadeInUp 1s ease-out 0.2s both;
	}

	:global(.fade-in-delay-2) {
		animation: fadeInUp 1s ease-out 0.4s both;
	}

	:global(.fade-in-delay-3) {
		animation: fadeInUp 1s ease-out 0.6s both;
	}

	/* Cool Scroll Effects */
	:global(::-webkit-scrollbar) {
		width: 12px;
	}

	:global(::-webkit-scrollbar-track) {
		background: rgba(0, 0, 0, 0.3);
		border-radius: 6px;
	}

	:global(::-webkit-scrollbar-thumb) {
		background: linear-gradient(45deg, #ff8c00, #dc143c);
		border-radius: 6px;
		box-shadow: 0 0 10px rgba(255, 140, 0, 0.5);
	}

	:global(::-webkit-scrollbar-thumb:hover) {
		background: linear-gradient(45deg, #dc143c, #ff8c00);
		box-shadow: 0 0 15px rgba(255, 140, 0, 0.8);
	}

	/* Responsive Design */
